{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Orchestrator",
  "version": "0.1.0",
  "identifier": "com.claudeorchestrator.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Claude Orchestrator",
        "width": 1320,
        "height": 860,
        "minWidth": 940,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/marius-bughiu/claude-orchestrator/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlFRTEyQTQwNUZDNTE3QTkKUldTcEY4VmZRQ3JobmtNNjBVeU05MDFMd1Z4U1lnY3B5V0M0Q3N0VElHUWMxSCtuN2JqeDBXdncK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "category": "DeveloperTool",
    "shortDescription": "Orchestrate autonomous coding agents across local repos.",
    "longDescription": "Claude Orchestrator coordinates Claude Code, Gemini, and Codex CLIs to autonomously work through tasks across multiple local git repositories, with a roadmap loop, verification, usage tracking, and a timeline.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
